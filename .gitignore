# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.ruff_cache

# Environments (depending on chosen one by developer)
.env
.venv
pvenv

# Settings
.env
**/compose.yaml

# User upload folder
media

# Assets folder (generated with the "python manage.py collectstatic" command)
assets

# Static file generated by django-tailwind, that is regenerated on the fly by the library
theme/static/css/dist/styles.css

# Files from celery
celerybeat-schedule
celerybeat-schedule-wal
celerybeat-schedule-shm

# Folder used in docker compose to store rabbitmq data
rabbitmq_data

# VisualStudioCode template
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
*.code-workspace

# Intellij idea
.idea

# Local History for devcontainer
.devcontainer/bash_history
